{
  "name": "ajosave",
  "version": "0.1.0",
  "private": false,
  "description": "Trustless rotating savings circles (Ajo/Esusu) on the Stellar blockchain.",
  "keywords": [
    "stellar",
    "soroban",
    "savings",
    "ajo",
    "esusu",
    "usdc",
    "defi",
    "nigeria"
  ],
  "homepage": "https://www.ajosave.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/JosephOnuh/ajosave.git"
  },
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint && npm run audit:sql",
    "lint:fix": "next lint --fix",
    "audit:sql": "ts-node scripts/audit-sql.ts",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "mobile:build": "next build && npx cap sync",
    "mobile:ios": "next build && npx cap sync ios && npx cap open ios",
    "mobile:android": "next build && npx cap sync android && npx cap open android",
    "cap:sync": "npx cap sync",
    "cap:copy": "npx cap copy",
    "contract:build": "cd contracts && stellar contract build",
    "contract:test": "cd contracts && cargo test",
    "contract:deploy": "ts-node scripts/deploy-contract.ts",
    "contract:verify": "ts-node scripts/verify-contract.ts",
    "migrate": "ts-node scripts/migrate.ts up",
    "migrate:down": "ts-node scripts/migrate.ts down",
    "migrate:create": "node-pg-migrate create --migrations-dir migrations",
    "prepare": "husky",
    "analyze": "ANALYZE=true npm run build"
  },
  "dependencies": {
    "@capacitor/android": "6.2.0",
    "@capacitor/core": "6.2.0",
    "@capacitor/ios": "6.2.0",
    "@capacitor/push-notifications": "6.0.2",
    "@hookform/resolvers": "^3.9.0",
    "@sentry/nextjs": "^8.28.0",
    "@stellar/freighter-api": "3.1.0",
    "@stellar/stellar-sdk": "^12.3.0",
    "@tanstack/react-query": "^5.40.0",
    "@vercel/analytics": "^1.1.0",
    "axios": "^1.7.2",
    "bullmq": "^5.7.8",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "ioredis": "^5.3.2",
    "jose": "^5.6.3",
    "next": "14.2.4",
    "next-auth": "^4.24.7",
    "next-intl": "^3.17.2",
    "node-pg-migrate": "^8.0.4",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.52.1",
    "redis": "^5.12.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.6",
    "@playwright/test": "^1.44.1",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.14.9",
    "@types/pg": "^8.11.6",
    "@types/pino": "^7.0.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/supertest": "^2.0.12",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.4",
    "eslint-config-prettier": "^9.1.1",
    "fast-check": "4.6.0",
    "husky": "^9.0.11",
    "ioredis": "^5.3.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.2.7",
    "prettier": "^3.3.2",
    "supertest": "^6.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3",
    "wait-on": "^8.0.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": "prettier --write"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
